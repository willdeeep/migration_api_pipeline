# Keep the build context tiny: only pyproject.toml, uv.lock, README.md, src/
# are needed to build the image.

.git
.gitignore
.github

# Local agent/workspace dirs
.opencode
.claude

# Virtualenv / caches
.venv
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Not needed at runtime
tests/
docs/
infra/

# Secrets / local env (runtime config is injected via compose env_file)
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
