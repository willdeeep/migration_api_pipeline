# Copy to .env and fill in. All runtime config is injected via env vars
# (locally from this file, in the cloud from the Cloud Run Job / Secret Manager).
# No secrets belong in the image or in source control.

# --- Source: Ducks Unlimited ArcGIS Feature Service ---
# Confirmed live endpoint (DU University Chapters, FeatureServer layer 0).
MIGRATION_SOURCE_URL=https://services2.arcgis.com/5I7u4SJE1vUr79JC/arcgis/rest/services/UniversityChapters_Public/FeatureServer/0/query
MIGRATION_SOURCE_PAGE_SIZE=1000
MIGRATION_REQUEST_TIMEOUT_SECONDS=30
MIGRATION_MAX_RETRIES=5

# --- Target: BigQuery ---
MIGRATION_GCP_PROJECT=your-gcp-project-id
MIGRATION_BQ_DATASET=migration
MIGRATION_BQ_TABLE=university_chapters
MIGRATION_BQ_LOCATION=US

# --- Observability ---
MIGRATION_LOG_LEVEL=INFO

# --- Auth (no JSON keys) ---
# Locally, authenticate once with Application Default Credentials:
#   gcloud auth application-default login
# The mounted ADC file is picked up automatically; do not set a key path.
